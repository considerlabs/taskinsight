# TaskInsight 환경 변수 템플릿
# 이 파일을 복사해서 .env로 만든 후 값을 채워주세요.
# cp .env.example .env

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me-strong-password
# Docker Compose 내부에서는 db:5432, 외부에서는 localhost:5433
DATABASE_URL=postgresql+psycopg://taskinsight:change-me-strong-password@db:5432/taskinsight

# ─── JWT 인증 ─────────────────────────────────────────────────────────────────
# 32자 이상 랜덤 문자열 (예: openssl rand -hex 32)
JWT_SECRET=replace-with-random-secret-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480  # 8시간

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Ollama (LLM) ─────────────────────────────────────────────────────────────
# 사내 서버에서 Ollama가 실행 중인 경우 host.docker.internal 또는 실제 IP
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL_TIMELINE=qwen3.6:35b-a3b
OLLAMA_MODEL_NARRATIVE=qwen2.5-coder:14b

# ─── 이메일 (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=taskinsight@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=TaskInsight <taskinsight@example.com>
SMTP_TLS=true

# ─── Teams 알림 ───────────────────────────────────────────────────────────────
# Teams 채널 → 연결기 → Incoming Webhook에서 URL 생성
TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/webhookb2/...

# ─── 파일 업로드 ──────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=20

# ─── Redmine (기존 분석 기능용, Phase 4 이후 제거) ───────────────────────────
REDMINE_BASE_URL=http://redmine.mannaplanet.co.kr:5555/redmine
REDMINE_API_KEY=your-redmine-api-key
COLLECTOR_INITIAL_LOOKBACK_DAYS=3650

# ─── 앱 설정 ─────────────────────────────────────────────────────────────────
APP_ENV=production         # development | production
APP_BASE_URL=http://your-server-ip-or-domain
FRONTEND_URL=http://your-server-ip-or-domain:3001

# ─── 초기 관리자 계정 (seed 실행 시 자동 생성) ────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-admin-password
ADMIN_DISPLAY_NAME=시스템 관리자
